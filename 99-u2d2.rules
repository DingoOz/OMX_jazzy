# ROBOTIS U2D2 USB-to-Dynamixel adapter
# Copy this file to /etc/udev/rules.d/ and reload rules:
#   sudo cp 99-u2d2.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
# Then unplug and replug the U2D2

# U2D2 (FTDI FT232R based)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6014", MODE="0666", SYMLINK+="u2d2"

# Alternative U2D2 (FT232H based)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", MODE="0666", SYMLINK+="u2d2"

# USB2Dynamixel (legacy)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", MODE="0666", SYMLINK+="usb2dynamixel"
